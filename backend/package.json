{
  "name": "tnp-backend",
  "version": "1.0.0",
  "description": "Production-level Training & Placement Backend with modular monolith architecture, REST + GraphQL, event-driven jobs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec 'ts-node -r tsconfig-paths/register' src/server.ts",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "migrate": "typeorm migration:run -d dist/config/database.js",
    "migrate:revert": "typeorm migration:revert -d dist/config/database.js",
    "migrate:generate": "typeorm migration:generate src/migrations/$npm_config_name -d dist/config/database.js",
    "seed": "ts-node scripts/seed.ts",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "health-check": "ts-node scripts/health-check.ts",
    "backup:db": "ts-node scripts/backup.ts",
    "restore:db": "ts-node scripts/restore.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.400.0",
    "@aws-sdk/client-sqs": "^3.400.0",
    "@elastic/elasticsearch": "^8.10.0",
    "@sentry/node": "^7.81.0",
    "apollo-server-express": "^3.13.0",
    "async": "^3.2.5",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cloudinary": "^1.41.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "fastify": "^4.24.3",
    "graphql": "^16.8.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^8.5.1",
    "kafkajs": "^2.2.4",
    "mammoth": "^1.6.0",
    "meilisearch": "^0.36.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.1",
    "qrcode": "^1.5.3",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "speakeasy": "^2.0.0",
    "stripe": "^14.13.0",
    "twilio": "^4.5.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1",
    "validator": "^13.11.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.6",
    "@types/speakeasy": "^2.0.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
