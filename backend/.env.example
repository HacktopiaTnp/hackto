# TnP Backend - Environment Variables Template
# Copy this to .env and fill in production values

# ============================================
# ENVIRONMENT & APP
# ============================================
NODE_ENV=production
PORT=3000
APP_NAME=TnP Backend
APP_VERSION=1.0.0

# ============================================
# DATABASE (PostgreSQL with RLS)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=tnp_user
DB_PASSWORD=change_me_in_production
DB_NAME=tnp_prod
DATABASE_URL=postgresql://tnp_user:change_me_in_production@localhost:5432/tnp_prod
DATABASE_SSL=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
SKIP_DATABASE_INIT=false

# Read Replica (for analytics queries)
DB_READ_REPLICA_HOST=read-replica.db.example.com
DB_READ_REPLICA_PORT=5432

# ============================================
# REDIS (Cache + Sessions + Rate Limiting)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER=false
REDIS_DB=0
SKIP_REDIS_INIT=false

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# FILE STORAGE & IMAGE HOSTING
# ============================================
# AWS S3 (File Storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=tnp-files-prod
S3_UPLOAD_FOLDER=uploads/
MAX_FILE_SIZE=52428800

# Cloudinary (Image hosting & optimization)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=tnp-portal
CLOUDINARY_UPLOAD_PRESET=unsigned_upload

# OR Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tnp.com

# ============================================
# KAFKA (Event Streaming)
# ============================================
KAFKA_BROKERS=kafka1:9092,kafka2:9092,kafka3:9092
KAFKA_CLIENT_ID=tnp-backend
KAFKA_GROUP_ID=tnp-group

# OR AWS SQS
AWS_SQS_QUEUE_URL=

# ============================================
# SEARCH (Elasticsearch or Meilisearch)
# ============================================
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
# Sentry
SENTRY_DSN=

# OpenTelemetry
OTEL_SDK_DISABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Grafana
GRAFANA_URL=http://localhost:3000

# Prometheus
PROMETHEUS_PUSH_GATEWAY=http://localhost:9091

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
HUGGINGFACE_API_KEY=

# ============================================
# SECURITY
# ============================================
# IP Allowlist for admins (comma-separated)
ADMIN_IP_ALLOWLIST=
# Enable MFA for admins
ENABLE_MFA=true
# Enable IP-based rate limiting
ENABLE_IP_RATE_LIMIT=true
# Secrets Manager (Vault)
VAULT_ADDR=
VAULT_TOKEN=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_GRAPHQL=true
ENABLE_WEBSOCKET=true
ENABLE_EVENTS=true
ENABLE_MOCK_DATA=false

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# MULTI-TENANCY
# ============================================
# Default tenant ID (for development)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000
